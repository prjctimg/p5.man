# Environment Variables Template
# Copy this file to .env and fill in your values

# GitHub API token for release monitoring
GITHUB_TOKEN=your_github_token_here

# Personal access token for p5.nvim repository commits
P5_NVIM_TOKEN=your_p5_nvim_token_here

# Optional: Target branch (defaults to main)
TARGET_BRANCH=main

# Optional: Enable debug logging
DEBUG=false

# Optional: p5.js repository (defaults to processing/p5.js)
P5_REPO=processing/p5.js

# Optional: p5.nvim repository (defaults to prjctimg/p5.nvim)
P5_NVIM_REPO=prjctimg/p5.nvim